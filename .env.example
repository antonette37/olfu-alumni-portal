# Database Configuration
# Copy this file to .env and fill in your actual values
DB_HOST=localhost
DB_USER=your_database_user
DB_PASS=your_database_password
DB_NAME=your_database_name
DB_PORT=3306

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=OLFU ALUMNI AFFAIRS

# Admin Email (for notifications)
ADMIN_EMAIL=admin@alumni.local

# Admin Account Password (for al_login.php and mobile API)
ADMIN_PASSWORD=your_secure_admin_password

# Affinda Resume Parser API
AFFINDA_API_KEY=your_affinda_api_key
AFFINDA_WORKSPACE=your_workspace_id

# Application Environment
ENVIRONMENT=production

# Support Email
SUPPORT_EMAIL=your-email@gmail.com


